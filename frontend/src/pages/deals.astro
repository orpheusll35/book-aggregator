---
import Layout from "../layouts/Layout.astro";
import Container from "@/components/ui/container";
import SectionHeader from "@/components/ui/section-header";
import BookCard from "@/components/BookCard";
import { fetchDeals } from "@/lib/fetchBooks";

const dealBooks = await fetchDeals(100);

---

<Layout title="Fırsatlar">
  <div class="bg-muted/30 min-h-screen py-10">
    <Container>
      <div class="mb-8">
        <div class="flex items-center gap-2 text-sm text-muted-foreground mb-4">
            <a href="/" class="hover:text-primary transition-colors">Anasayfa</a>
            <span>/</span>
            <span class="text-foreground font-medium">Fırsatlar</span>
        </div>
        
        <SectionHeader
          title="Günün Fırsatları"
          subtitle="En iyi fiyatlarla yakalayabileceğiniz indirimli kitaplar."
        />
      </div>

      {dealBooks.length > 0 ? (
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
          {dealBooks.map((book) => (
            <BookCard book={book} client:load />
          ))}
        </div>
      ) : (
        <div class="text-center py-20 bg-white rounded-xl border border-dashed">
          <h3 class="text-lg font-medium text-muted-foreground">Şu anda aktif bir fırsat bulunmuyor.</h3>
          <p class="text-sm text-muted-foreground mt-2">Lütfen daha sonra tekrar kontrol edin!</p>
        </div>
      )}
    </Container>
  </div>
</Layout>
